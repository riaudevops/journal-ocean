---
import Layout from "../layouts/Layout.astro";
import HeroWithSidebar from "../components/pages/berita/HeroWithSidebar.astro";
import LatestBeritaCarousel from "../components/pages/berita/LatestBeritaCarousel.astro";
import { getPublishedNews, normalizeSiteLanguage } from "../lib/directus";

const language = normalizeSiteLanguage(Astro.url.searchParams.get("lang"));
const allBeritaData = await getPublishedNews(language, 20);
const heroBerita =
  allBeritaData.find((item) => item.is_featured) ?? allBeritaData[0] ?? null;
const sidebarBerita = allBeritaData
  .filter((item) => item.slug !== heroBerita?.slug)
  .slice(0, 5);
const latestBerita = [...allBeritaData].sort(
  (a, b) =>
    new Date(b.date_created ?? "").getTime() -
    new Date(a.date_created ?? "").getTime()
);
const pageTitle = language === "en" ? "News" : "Berita";
const emptyTitle = language === "en" ? "No news yet" : "Belum ada berita";
const emptyDescription =
  language === "en"
    ? "Published news from Journal Ocean will appear here."
    : "Berita yang sudah dipublikasikan dari Journal Ocean akan tampil di sini.";
---

<Layout title={pageTitle}>
  <section class="bg-gradient-to-br from-brand-background via-brand-surface to-brand-background py-8 lg:py-16 overflow-hidden relative">
    <div class="container mx-auto px-6 md:px-8 max-w-7xl relative z-10 mt-10">
      {heroBerita ? (
        <div class="flex flex-col gap-16">
          {/* Hero Section with Sidebar */}
          <HeroWithSidebar
            heroBerita={heroBerita}
            sidebarBerita={sidebarBerita}
            language={language}
          />

          {/* Latest berita Carousel */}
          <LatestBeritaCarousel latestBerita={latestBerita} language={language} />
        </div>
      ) : (
        <div class="mx-auto max-w-2xl py-32 text-center">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-brand-primary">
            Journal Ocean
          </p>
          <h1 class="font-serif text-4xl text-brand-text md:text-5xl">
            {emptyTitle}
          </h1>
          <p class="mt-5 text-base leading-7 text-brand-text/70">
            {emptyDescription}
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>
