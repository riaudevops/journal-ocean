---
import { ChevronRight } from '@lucide/astro';
import {
  getNavbarContentWithFallback,
  normalizeSiteLanguage,
} from '../../lib/directus';

export interface SubSubItem {
  name: string;
  href: string;
  langKey: string;
}

export interface SubItem {
  name: string;
  href: string;
  langKey: string;
  subSubItems?: SubSubItem[];
}

export interface MenuItem {
  name: string;
  href: string;
  langKey: string;
  subItems?: SubItem[];
}

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const navbarContent = await getNavbarContentWithFallback(language);
const logoText = navbarContent.text_icon ?? 'Journal Ocean';
const logoSubText = navbarContent.text_sub_icon ?? 'Jurnal';

const menuItems: MenuItem[] = [
  { name: navbarContent.item_1 ?? 'Home', href: '/', langKey: 'nav.home' },
  {
    name: navbarContent.item_2 ?? 'Tentang Kami',
    href: '/profil',
    langKey: 'nav.about',
    subItems: [
      {
        name: navbarContent.subitem2_1 ?? 'Profil',
        href: '/profil',
        langKey: 'nav.profile',
      },
      {
        name: navbarContent.subitem2_2 ?? 'Visi & Misi',
        href: '/profil#visi-misi',
        langKey: 'nav.vision',
      },
      {
        name: navbarContent.subitem2_3 ?? 'Struktur Organisasi',
        href: '/profil#struktur-organisasi',
        langKey: 'nav.structure',
      },
    ],
  },
  {
    name: navbarContent.item_3 ?? 'Program',
    href: '/program',
    langKey: 'nav.programs',
    subItems: [
      {
        name: navbarContent.subitem3_1 ?? 'Program Sosial',
        href: '/program#sosial',
        langKey: 'nav.social',
      },
      {
        name: navbarContent.subitem3_2 ?? 'Program Kemanusiaan',
        href: '/program#kemanusiaan',
        langKey: 'nav.humanitarian',
      },
      {
        name: navbarContent.subitem3_3 ?? 'Program Keagamaan',
        href: '/program#keagamaan',
        langKey: 'nav.religious',
      },
    ],
  },
  {
    name: navbarContent.item_4 ?? 'Berita',
    href: '/berita',
    langKey: 'nav.news',
  },
];
---

<div
  class="w-full fixed top-0 left-0 right-0 z-100 transition-all duration-500 ease-out"
  id="navbar-wrapper"
>
  <nav
    class="w-full bg-brand-primary text-brand-background shadow-lg relative z-100 transition-all duration-500 ease-out"
    id="navbar"
  >
    <div
      class="w-full max-w-7xl mx-auto flex justify-between items-center px-4 py-3 sm:px-5 lg:px-6 2xl:px-8 sm:py-4"
    >
      <a
        href="/"
        class="flex min-w-0 items-baseline gap-2 sm:gap-3 cursor-pointer hover:opacity-90 transition-opacity duration-200 shrink overflow-hidden"
      >
        <span class="logo-mark">S</span>
        <span class="logo-name hidden sm:inline">{logoText}</span>
        <span class="logo-sub hidden sm:inline">{logoSubText}</span>
      </a>

      <div class="hidden xl:flex items-center gap-8">
        <ul
          class="flex items-center gap-8 text-brand-background font-medium text-[0.85rem]"
        >
          {
            menuItems.map((item) => (
              <li class={`relative group ${item.subItems && 'cursor-pointer'}`}>
                <a
                  href={item.href}
                  class={`hover:text-brand-primary-lighter transition-colors duration-200 ${!item.subItems && 'cursor-pointer'} nav-link`}
                >
                  <span data-i18n={item.langKey}>{item.name}</span>
                  {item.subItems && (
                    <svg
                      class="inline w-4 h-4 ml-1 transition-transform duration-300 group-hover:rotate-180"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  )}
                </a>
                {item.subItems && (
                  <div class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-brand-primary/95 backdrop-blur-sm text-brand-background shadow-xl rounded-lg mt-2 z-110 border border-white/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out transform translate-y-2 group-hover:translate-y-0">
                    <div class="py-2">
                      {item.subItems.map((subItem) => (
                        <div class="relative group/sub">
                          <a
                            href={subItem.href}
                            class="w-full flex justify-between items-center px-4 py-2 hover:bg-white/10 hover:text-brand-primary-lighter transition-all duration-200"
                          >
                            <span data-i18n={subItem.langKey}>
                              {subItem.name}
                            </span>
                            {subItem.subSubItems && (
                              <ChevronRight class="w-4 h-4 transition-transform duration-300 group-hover/sub:translate-x-1" />
                            )}
                          </a>

                          {subItem.subSubItems && (
                            <div class="absolute top-0 left-full w-56 bg-brand-primary/95 backdrop-blur-sm text-brand-background shadow-xl rounded-lg ml-2 z-120 border border-white/10 opacity-0 invisible group-hover/sub:opacity-100 group-hover/sub:visible transition-all duration-300 ease-out transform -translate-x-2 group-hover/sub:translate-x-0">
                              <div class="py-2">
                                {subItem.subSubItems.map((subSubItem) => (
                                  <a
                                    href={subSubItem.href}
                                    class="block px-4 py-2 hover:bg-white/10 hover:text-brand-primary-lighter transition-all duration-200 hover:pl-5"
                                  >
                                    {subSubItem.href}
                                  </a>
                                ))}
                              </div>
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </li>
            ))
          }
        </ul>

        <div class="language-toggle" aria-label="Pilih bahasa">
          <button
            type="button"
            class="language-toggle-btn is-active"
            data-lang-option="id"
            aria-pressed="true">ID</button
          >
          <button
            type="button"
            class="language-toggle-btn"
            data-lang-option="en"
            aria-pressed="false">EN</button
          >
        </div>
      </div>

      <div
        class="xl:hidden flex shrink-0 gap-1.5 sm:gap-2 md:gap-3 justify-center items-center"
      >
        <div
          class="language-toggle language-toggle-mobile"
          aria-label="Pilih bahasa"
        >
          <button
            type="button"
            class="language-toggle-btn is-active"
            data-lang-option="id"
            aria-pressed="true">ID</button
          >
          <button
            type="button"
            class="language-toggle-btn"
            data-lang-option="en"
            aria-pressed="false">EN</button
          >
        </div>
        <button
          id="hamburger-button"
          class="flex h-10 w-10 items-center justify-center rounded-full text-brand-background focus:outline-none transition-transform duration-300 active:scale-90 sm:h-11 sm:w-11"
        >
          <svg
            id="hamburger-icon"
            class="md:w-8 md:h-8 w-6 h-6 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="fixed top-0 left-0 z-100 h-full w-full overflow-y-auto bg-brand-primary/98 backdrop-blur-sm transform -translate-y-full transition-transform duration-500 ease-in-out xl:hidden"
  >
    <div
      class="mx-auto mt-13 w-full max-w-3xl px-4 pb-6 sm:mt-15 sm:px-5 sm:pb-8"
    >
      <div
        class="overflow-hidden rounded-3xl border border-white/10 bg-white/4 text-brand-background shadow-[0_20px_50px_rgba(0,0,0,0.18)]"
      >
        {
          menuItems.map((item) => (
            <div class="border-b border-white/10 px-4 py-3.5 transition-colors duration-200 hover:bg-white/5 last:border-b-0 sm:px-5 sm:py-4">
              {!item.subItems ? (
                <a
                  href={item.href}
                  class="block w-full text-[15px] leading-6 hover:text-brand-primary-lighter transition-colors duration-200 sm:text-base"
                >
                  <span data-i18n={item.langKey}>{item.name}</span>
                </a>
              ) : (
                <div>
                  <button class="accordion-toggle flex w-full items-center justify-between gap-4 text-left text-[15px] leading-6 hover:text-brand-primary-lighter transition-colors duration-200 sm:text-base">
                    <span data-i18n={item.langKey}>{item.name}</span>
                    <svg
                      class="h-4 w-4 shrink-0 transition-transform duration-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </button>
                  <div class="accordion-panel max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                    <div class="mt-3 flex flex-col gap-2 rounded-2xl bg-white/5 px-3.5 py-3">
                      {item.subItems.map((subItem) =>
                        !subItem.subSubItems ? (
                          <a
                            href={subItem.href}
                            class="block py-0.5 text-[14px] font-medium leading-6 text-brand-primary-lighter/80 hover:pl-2 hover:text-brand-background transition-all duration-200 sm:text-[15px]"
                          >
                            <span data-i18n={subItem.langKey}>
                              {subItem.name}
                            </span>
                          </a>
                        ) : (
                          <div>
                            <button class="accordion-toggle flex w-full items-center gap-3 py-0.5 text-left text-[14px] font-medium leading-6 text-brand-primary-lighter/80 hover:text-brand-background transition-colors duration-200 sm:text-[15px]">
                              <span data-i18n={subItem.langKey}>
                                {subItem.name}
                              </span>
                              <svg
                                class="h-4 w-4 shrink-0 transition-transform duration-300"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M19 9l-7 7-7-7"
                                />
                              </svg>
                            </button>
                            <div class="accordion-panel max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                              <div class="mt-2 flex flex-col gap-1.5 rounded-xl bg-white/5 py-2 pl-3 pr-2.5">
                                {subItem.subSubItems.map((subSubItem) => (
                                  <a
                                    href={subSubItem.href}
                                    class="block py-0.5 text-[13px] font-medium leading-5 text-brand-primary-lighter/70 hover:pl-2 hover:text-brand-background transition-all duration-200 sm:text-sm"
                                  >
                                    <span data-i18n={subSubItem.langKey}>
                                      {subSubItem.name}
                                    </span>
                                  </a>
                                ))}
                              </div>
                            </div>
                          </div>
                        )
                      )}
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <style>
    .logo-mark {
      font-family: 'Fraunces', 'Times New Roman', serif;
      font-style: italic;
      font-weight: 400;
      font-size: 24px;
      line-height: 1;
      color: var(--color-primary-lighter);
      flex-shrink: 0;
    }

    .logo-name {
      font-family: 'Fraunces', 'Times New Roman', serif;
      font-weight: 600;
      font-size: 18px;
      letter-spacing: -0.01em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .logo-sub {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-primary-lighter);
      padding-left: 8px;
      margin-left: 2px;
      border-left: 1px solid rgba(164, 178, 147, 0.4);
      white-space: nowrap;
      flex-shrink: 0;
    }

    @media (min-width: 640px) {
      .logo-mark {
        font-size: 28px;
      }

      .logo-name {
        font-size: 20px;
      }

      .logo-sub {
        font-size: 10px;
        letter-spacing: 0.25em;
        padding-left: 12px;
        margin-left: 4px;
      }
    }

    @media (max-width: 479px) {
      .logo-sub {
        display: none;
      }
    }

    .nav-cta {
      display: inline-flex;
      align-items: center;
      background: var(--color-primary-lighter);
      color: var(--color-primary-darker);
      padding: 10px 20px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 100px;
      transition:
        background 0.2s,
        color 0.2s;
    }

    .nav-cta:hover {
      background: var(--color-background);
      color: var(--color-primary-darker);
    }

    .nav-link {
      position: relative;
      padding: 6px 0;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      left: 50%;
      bottom: -2px;
      width: 0;
      height: 1.5px;
      background: var(--color-primary-lighter);
      transition:
        width 0.3s,
        left 0.3s;
    }

    .nav-link:hover::after {
      width: 100%;
      left: 0;
    }

    .language-toggle {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 3px;
      border: 1px solid rgba(164, 178, 147, 0.42);
      border-radius: 999px;
      background: rgba(247, 242, 231, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .language-toggle-btn {
      min-width: 34px;
      height: 28px;
      border-radius: 999px;
      color: rgba(247, 242, 231, 0.72);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1;
      text-transform: uppercase;
      transition:
        background 0.2s ease,
        color 0.2s ease,
        transform 0.2s ease;
      cursor: pointer;
    }

    .language-toggle-btn:hover {
      color: var(--color-background);
      transform: translateY(-1px);
    }

    .language-toggle-btn.is-active {
      background: var(--color-primary-lighter);
      color: var(--color-primary-darker);
      box-shadow: 0 8px 18px rgba(42, 46, 37, 0.18);
    }

    .language-toggle-mobile .language-toggle-btn {
      min-width: 30px;
      height: 24px;
      font-size: 10px;
    }

    @media (min-width: 640px) {
      .language-toggle-mobile .language-toggle-btn {
        min-width: 32px;
        height: 26px;
      }
    }
  </style>

  <script>
    type Language = 'id' | 'en';

    const languageStorageKey = 'journal-ocean-lang';
    const languageScrollStorageKey = 'journal-ocean-language-scroll-y';

    const saveLanguageScrollPosition = () => {
      try {
        sessionStorage.setItem(
          languageScrollStorageKey,
          String(window.scrollY)
        );
      } catch {
        // Ignore storage errors, for example in restricted/private browser modes.
      }
    };

    const restoreLanguageScrollPosition = () => {
      try {
        const savedPosition = sessionStorage.getItem(languageScrollStorageKey);
        if (!savedPosition) return;

        sessionStorage.removeItem(languageScrollStorageKey);

        const scrollY = Number(savedPosition);
        if (!Number.isFinite(scrollY) || scrollY < 0) return;

        if ('scrollRestoration' in window.history) {
          window.history.scrollRestoration = 'manual';
        }

        const restore = () => {
          window.scrollTo({ top: scrollY, left: 0, behavior: 'instant' });
        };

        // Run several times because SSR content, image layout, and the preloader can
        // change the document height shortly after the initial page render.
        requestAnimationFrame(restore);
        setTimeout(restore, 80);
        setTimeout(restore, 300);
        setTimeout(restore, 900);
        setTimeout(restore, 1600);
      } catch {
        // Keep language switching functional even if scroll restoration fails.
      }
    };

    restoreLanguageScrollPosition();

    const updateLanguageQuery = (
      language: Language,
      preserveScroll = false
    ) => {
      const url = new URL(window.location.href);
      url.searchParams.set('lang', language);

      if (preserveScroll) {
        saveLanguageScrollPosition();
      }

      window.location.href = url.toString();
    };

    const setLanguage = (language: Language) => {
      document.documentElement.lang = language;

      document
        .querySelectorAll<HTMLButtonElement>('[data-lang-option]')
        .forEach((button) => {
          const isActive = button.dataset.langOption === language;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', String(isActive));
        });

      localStorage.setItem(languageStorageKey, language);
    };

    const urlLanguage = new URLSearchParams(window.location.search).get('lang');
    const storedLanguage = localStorage.getItem(languageStorageKey);
    const initialLanguage: Language =
      urlLanguage === 'en'
        ? 'en'
        : urlLanguage === 'id'
          ? 'id'
          : storedLanguage === 'en'
            ? 'en'
            : 'id';
    setLanguage(initialLanguage);

    if (!urlLanguage && initialLanguage === 'en') {
      updateLanguageQuery('en');
    }

    document
      .querySelectorAll<HTMLButtonElement>('[data-lang-option]')
      .forEach((button) => {
        button.addEventListener('click', () => {
          const selectedLanguage =
            button.dataset.langOption === 'en' ? 'en' : 'id';
          setLanguage(selectedLanguage);
          updateLanguageQuery(selectedLanguage, true);
        });
      });

    const hamburgerButton = document.getElementById('hamburger-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');

    hamburgerButton!.addEventListener('click', () => {
      const isMenuOpen = !mobileMenu!.classList.contains('-translate-y-full');

      if (isMenuOpen) {
        mobileMenu!.classList.add('-translate-y-full');
        hamburgerIcon!.classList.remove('rotate-90');
      } else {
        mobileMenu!.classList.remove('-translate-y-full');
        hamburgerIcon!.classList.add('rotate-90');
      }
    });

    const accordions = document.querySelectorAll('.accordion-toggle');
    accordions.forEach((accordion) => {
      accordion.addEventListener('click', () => {
        const panel = accordion.nextElementSibling as HTMLElement;
        const icon = accordion.querySelector('svg');

        if (panel.style.maxHeight && panel.style.maxHeight !== '0px') {
          panel.style.maxHeight = '0px';
          icon!.classList.remove('rotate-180');
        } else {
          panel.style.maxHeight = panel.scrollHeight + 'px';
          icon!.classList.add('rotate-180');
        }
      });
    });
  </script>
</div>
