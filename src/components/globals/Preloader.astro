---
// Editorial Warm preloader — jurnal laut, arsip, dan kompas kecil.
import {
  getPreloaderContentWithFallback,
  normalizeSiteLanguage,
} from '../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const preloaderContent = await getPreloaderContentWithFallback(language);
---

<div
  id="preloader"
  class="preloader"
  aria-live="polite"
  aria-label={preloaderContent.aria_label}
>
  <div class="preloader__grain" aria-hidden="true"></div>
  <div class="preloader__orb preloader__orb--sage" aria-hidden="true"></div>
  <div class="preloader__orb preloader__orb--rust" aria-hidden="true"></div>

  <section class="preloader__card">
    <div class="preloader__folio" aria-hidden="true">
      <span>{preloaderContent.code_label}</span>
      <span>{preloaderContent.coordinate_label}</span>
    </div>

    <div class="preloader__mark" aria-hidden="true">
      <div class="preloader__rings">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="preloader__compass">
        <span class="preloader__needle"></span>
        <span class="preloader__dot"></span>
      </div>
    </div>

    <div class="preloader__copy">
      <p class="preloader__eyebrow">{preloaderContent.eyebrow}</p>
      <h1>{preloaderContent.title}</h1>
      <p class="preloader__text">{preloaderContent.description}</p>
    </div>

    <div class="preloader__progress" aria-hidden="true">
      <div id="progress-bar" class="preloader__progress-fill"></div>
    </div>

    <div class="preloader__footer" aria-hidden="true">
      <span>{preloaderContent.footer_label}</span>
      <span>{preloaderContent.loading_label}</span>
    </div>
  </section>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: clamp(0.65rem, 3vw, 1.5rem);
    color: #2a2e25;
    background:
      radial-gradient(
        circle at 18% 18%,
        rgba(164, 178, 147, 0.34),
        transparent 28rem
      ),
      radial-gradient(
        circle at 82% 76%,
        rgba(184, 112, 74, 0.18),
        transparent 24rem
      ),
      linear-gradient(135deg, #f7f2e7 0%, #ebe3d2 100%);
    transition:
      opacity 520ms ease,
      visibility 520ms ease;
  }

  .preloader.is-leaving {
    opacity: 0;
    visibility: hidden;
  }

  .preloader__grain {
    position: absolute;
    inset: 0;
    opacity: 0.42;
    background-image:
      linear-gradient(rgba(74, 93, 63, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 93, 63, 0.032) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(circle at center, black, transparent 76%);
  }

  .preloader__orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(10px);
    opacity: 0.62;
    animation: preloader-drift 5.8s ease-in-out infinite alternate;
  }

  .preloader__orb--sage {
    top: 14%;
    left: 10%;
    width: 10rem;
    height: 10rem;
    background: rgba(164, 178, 147, 0.28);
  }

  .preloader__orb--rust {
    right: 12%;
    bottom: 12%;
    width: 8rem;
    height: 8rem;
    background: rgba(184, 112, 74, 0.16);
    animation-delay: -1.2s;
  }

  .preloader__card {
    position: relative;
    box-sizing: border-box;
    width: min(100%, 720px);
    min-height: clamp(360px, 68dvh, 430px);
    max-height: calc(100dvh - clamp(1.3rem, 6vw, 3rem));
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1fr);
    gap: clamp(1rem, 3.5vw, 2.75rem);
    align-items: center;
    padding: clamp(1.5rem, 4vw, 3.2rem);
    border: 1px solid rgba(74, 93, 63, 0.16);
    border-radius: 2.25rem;
    background:
      linear-gradient(
        115deg,
        rgba(255, 253, 247, 0.88),
        rgba(235, 227, 210, 0.76)
      ),
      #fffdf7;
    box-shadow: 0 32px 90px rgba(74, 93, 63, 0.16);
    isolation: isolate;
  }

  .preloader__card::before {
    content: '';
    position: absolute;
    inset: 1rem;
    z-index: -1;
    border: 1px dashed rgba(74, 93, 63, 0.22);
    border-radius: 1.65rem;
  }

  .preloader__folio,
  .preloader__footer {
    position: absolute;
    left: clamp(1.5rem, 4vw, 3.2rem);
    right: clamp(1.5rem, 4vw, 3.2rem);
    display: flex;
    justify-content: space-between;
    min-width: 0;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(74, 93, 63, 0.68);
  }

  .preloader__folio span,
  .preloader__footer span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preloader__folio {
    top: 1.3rem;
  }

  .preloader__footer {
    bottom: 1.25rem;
  }

  .preloader__mark {
    position: relative;
    aspect-ratio: 1;
    width: clamp(8.75rem, 28vw, 240px);
    justify-self: center;
  }

  .preloader__rings,
  .preloader__rings span,
  .preloader__compass {
    position: absolute;
    inset: 0;
    border-radius: 999px;
  }

  .preloader__rings {
    border: 1px solid rgba(74, 93, 63, 0.18);
    background:
      repeating-radial-gradient(
        circle,
        transparent 0 15px,
        rgba(74, 93, 63, 0.045) 16px 17px
      ),
      rgba(235, 227, 210, 0.42);
    animation: preloader-breathe 2.6s ease-in-out infinite;
  }

  .preloader__rings span {
    border: 1px solid rgba(74, 93, 63, 0.16);
    transform: scale(var(--scale));
  }

  .preloader__rings span:nth-child(1) {
    --scale: 0.76;
  }

  .preloader__rings span:nth-child(2) {
    --scale: 0.52;
  }

  .preloader__rings span:nth-child(3) {
    --scale: 0.28;
    background: #f7f2e7;
  }

  .preloader__compass {
    display: grid;
    place-items: center;
    animation: preloader-compass 4s cubic-bezier(0.7, 0, 0.25, 1) infinite;
  }

  .preloader__needle {
    width: 0.35rem;
    height: 54%;
    border-radius: 999px;
    background: linear-gradient(180deg, #b8704a 0 48%, #4a5d3f 52% 100%);
    box-shadow: 0 10px 28px rgba(74, 93, 63, 0.18);
  }

  .preloader__dot {
    position: absolute;
    width: 1.15rem;
    height: 1.15rem;
    border: 3px solid #f7f2e7;
    border-radius: 999px;
    background: #4a5d3f;
  }

  .preloader__copy {
    min-width: 0;
    padding-block: 2.25rem;
  }

  .preloader__eyebrow {
    margin: 0 0 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.58rem, 1.8vw, 0.72rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #6b7a5a;
  }

  .preloader__copy h1 {
    margin: 0;
    max-width: 11ch;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2.15rem, 7vw, 5.2rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.055em;
    overflow-wrap: anywhere;
    text-wrap: balance;
    color: #2a2e25;
  }

  .preloader__text {
    max-width: 29rem;
    margin: 1.35rem 0 0;
    font-size: clamp(0.86rem, 2.3vw, 0.98rem);
    line-height: 1.8;
    color: rgba(42, 46, 37, 0.68);
  }

  .preloader__progress {
    position: absolute;
    left: clamp(1.5rem, 4vw, 3.2rem);
    right: clamp(1.5rem, 4vw, 3.2rem);
    bottom: 3.55rem;
    height: 0.42rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(74, 93, 63, 0.12);
  }

  .preloader__progress-fill {
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #4a5d3f, #a4b293 48%, #b8704a);
    transition: width 180ms ease;
  }

  @media (max-width: 720px) {
    .preloader__card {
      min-height: min(620px, calc(100dvh - 1.5rem));
      grid-template-columns: 1fr;
      align-content: center;
      justify-items: center;
      padding: clamp(1.6rem, 6vw, 2.4rem);
      padding-block: 4.35rem 4.8rem;
      text-align: center;
    }

    .preloader__card::before {
      inset: 0.72rem;
      border-radius: 1.35rem;
    }

    .preloader__folio,
    .preloader__footer {
      left: clamp(1.25rem, 6vw, 2rem);
      right: clamp(1.25rem, 6vw, 2rem);
      font-size: clamp(0.54rem, 2.15vw, 0.64rem);
      letter-spacing: 0.11em;
    }

    .preloader__mark {
      width: clamp(7.75rem, 44vw, 180px);
    }

    .preloader__copy {
      padding-block: 0;
    }

    .preloader__copy h1,
    .preloader__text {
      margin-inline: auto;
    }

    .preloader__copy h1 {
      max-width: 12ch;
      font-size: clamp(2rem, 11vw, 3.45rem);
      line-height: 0.95;
    }

    .preloader__text {
      max-width: 28ch;
      margin-top: 1rem;
      line-height: 1.65;
    }

    .preloader__progress {
      left: clamp(1.25rem, 6vw, 2rem);
      right: clamp(1.25rem, 6vw, 2rem);
      bottom: 3.25rem;
    }
  }

  @media (max-width: 420px), (max-height: 620px) {
    .preloader__card {
      border-radius: 1.55rem;
      min-height: auto;
      max-height: calc(100dvh - 1rem);
      padding: 3.7rem 1rem 4.15rem;
      gap: 0.8rem;
    }

    .preloader__card::before {
      inset: 0.55rem;
      border-radius: 1.1rem;
    }

    .preloader__folio,
    .preloader__footer {
      left: 1rem;
      right: 1rem;
      gap: 0.45rem;
      font-size: 0.5rem;
      letter-spacing: 0.08em;
    }

    .preloader__folio {
      top: 1rem;
    }

    .preloader__footer {
      bottom: 0.95rem;
    }

    .preloader__mark {
      width: clamp(6.6rem, 36dvh, 8.75rem);
    }

    .preloader__eyebrow {
      margin-bottom: 0.65rem;
      letter-spacing: 0.12em;
    }

    .preloader__copy h1 {
      max-width: 11ch;
      font-size: clamp(1.75rem, 10.5vw, 2.65rem);
      letter-spacing: -0.04em;
    }

    .preloader__text {
      max-width: 27ch;
      margin-top: 0.8rem;
      font-size: 0.78rem;
      line-height: 1.55;
    }

    .preloader__progress {
      left: 1rem;
      right: 1rem;
      bottom: 2.75rem;
      height: 0.34rem;
    }
  }
</style>

<script>
  const waitForCriticalImages = (): Promise<void> => {
    const images = Array.from(document.querySelectorAll('img'));
    const criticalImages = images.filter((img) => {
      const rect = img.getBoundingClientRect();
      const isAboveFold = rect.top < window.innerHeight * 1.5;
      const isEager =
        img.getAttribute('loading') === 'eager' || !img.hasAttribute('loading');
      return isAboveFold || isEager;
    });

    const imagePromises = criticalImages.map((img) => {
      if (img.complete) return Promise.resolve();
      return new Promise<void>((resolve) => {
        const timeout = window.setTimeout(resolve, 900);
        img.addEventListener(
          'load',
          () => {
            window.clearTimeout(timeout);
            resolve();
          },
          { once: true }
        );
        img.addEventListener(
          'error',
          () => {
            window.clearTimeout(timeout);
            resolve();
          },
          { once: true }
        );
      });
    });

    return Promise.all(imagePromises).then(() => undefined);
  };

  const initPreloader = async () => {
    const preloader = document.getElementById('preloader');
    const progressBar = document.getElementById('progress-bar');
    if (!preloader || !progressBar) return;

    document.body.style.overflow = 'hidden';

    let progress = 8;
    progressBar.style.width = `${progress}%`;

    const progressInterval = window.setInterval(() => {
      progress = Math.min(92, progress + Math.random() * 14 + 6);
      progressBar.style.width = `${progress}%`;
    }, 110);

    const closePreloader = () => {
      window.clearInterval(progressInterval);
      progressBar.style.width = '100%';

      window.setTimeout(() => {
        preloader.classList.add('is-leaving');
        document.body.style.overflow = '';
      }, 180);

      window.setTimeout(() => {
        preloader.remove();
      }, 760);
    };

    const maxWait = new Promise<void>((resolve) => {
      window.setTimeout(resolve, 1900);
    });

    await Promise.race([waitForCriticalImages(), maxWait]);
    closePreloader();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPreloader, {
      once: true,
    });
  } else {
    initPreloader();
  }
</script>
