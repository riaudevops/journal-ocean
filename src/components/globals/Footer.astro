---
import { MapPin, Phone, Mail, Clock, Facebook, Instagram, Twitter, Youtube } from "lucide-astro";
import {
  getFooterContentWithFallback,
  normalizeSiteLanguage,
} from "../../lib/directus";

const currentYear = new Date().getFullYear();
const language = normalizeSiteLanguage(Astro.url.searchParams.get("lang"));
const footerContent = await getFooterContentWithFallback(language);

const formatFooterText = (value?: string) =>
  (value ?? "").replace(/\r\n/g, "\n").split("\n");

const copyrightText = (footerContent.copyright_text ?? "Journal Ocean ©{year}. All rights reserved.").replace(
  "{year}",
  String(currentYear),
);

const aboutLinks = [
  {
    label: footerContent.about_link_1_label ?? "Profil Journal Ocean",
    href: footerContent.about_link_1_href ?? "/profil",
  },
  {
    label: footerContent.about_link_2_label ?? "Visi & Misi",
    href: footerContent.about_link_2_href ?? "/profil#visi-misi",
  },
  {
    label: footerContent.about_link_3_label ?? "Struktur",
    href: footerContent.about_link_3_href ?? "/profil#struktur",
  },
].filter((item) => item.label);

const programLinks = [
  {
    label: footerContent.program_link_1_label ?? "Sosial",
    href: footerContent.program_link_1_href ?? "/program#sosial",
  },
  {
    label: footerContent.program_link_2_label ?? "Kemanusiaan",
    href: footerContent.program_link_2_href ?? "/program#kemanusiaan",
  },
  {
    label: footerContent.program_link_3_label ?? "Keagamaan",
    href: footerContent.program_link_3_href ?? "/program#keagamaan",
  },
].filter((item) => item.label);

const normalizeExternalUrl = (value?: string) => {
  if (!value) return "";
  if (value === "#" || value.startsWith("/") || /^(https?:|mailto:|tel:)/i.test(value)) {
    return value;
  }
  return `https://${value}`;
};

const socialLinks = [
  {
    label: footerContent.facebook_label,
    href: normalizeExternalUrl(footerContent.facebook_url),
    Icon: Facebook,
  },
  {
    label: footerContent.instagram_label,
    href: normalizeExternalUrl(footerContent.instagram_url),
    Icon: Instagram,
  },
  {
    label: footerContent.twitter_label,
    href: normalizeExternalUrl(footerContent.twitter_url),
    Icon: Twitter,
  },
  {
    label: footerContent.youtube_label,
    href: normalizeExternalUrl(footerContent.youtube_url),
    Icon: Youtube,
  },
].filter((item) => item.label && item.href);

const legalLinks = [
  {
    label: footerContent.privacy_label ?? "Kebijakan Privasi",
    href: footerContent.privacy_href ?? "#",
  },
  {
    label: footerContent.terms_label ?? "Syarat & Ketentuan",
    href: footerContent.terms_href ?? "#",
  },
].filter((item) => item.label);
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <!-- Brand Section -->
      <div>
        <div class="footer-brand">{footerContent.brand_name ?? "Journal Ocean"}</div>
        <div class="footer-brand-sub">{footerContent.brand_subtitle ?? "Jurnal · Sejak 2014"}</div>
        <p class="footer-tag">{footerContent.tagline}</p>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4>{footerContent.about_title ?? "Tentang"}</h4>
        <ul>
          {aboutLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Program -->
      <div class="footer-col">
        <h4>{footerContent.program_title ?? "Program"}</h4>
        <ul>
          {programLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Kontak -->
      <div class="footer-col">
        <h4>{footerContent.contact_title ?? "Hubungi"}</h4>
        <ul class="footer-contact">
          <li class="flex items-start gap-2">
            <MapPin class="w-4 h-4 mt-1 shrink-0" />
            <a href={footerContent.address_href ?? "#"}>
              {formatFooterText(footerContent.address_text).map((line, index) => (
                <>{index > 0 && <br />}{line}</>
              ))}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <Phone class="w-4 h-4 shrink-0" />
            <a href={footerContent.phone_href ?? "#"}>{footerContent.phone_label}</a>
          </li>
          <li class="flex items-center gap-2">
            <Mail class="w-4 h-4 shrink-0" />
            <a href={footerContent.email_href ?? "#"}>{footerContent.email_label}</a>
          </li>
          <li class="flex items-center gap-2">
            <Clock class="w-4 h-4 shrink-0" />
            <span>
              {formatFooterText(footerContent.office_hours_text).map((line, index) => (
                <>{index > 0 && <br />}{line}</>
              ))}
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Social Media -->
    <div class="footer-social">
      <div class="footer-social-row">
        <div class="flex items-center gap-2">
          <span class="footer-social-label">{footerContent.social_label ?? "Ikuti Kami:"}</span>
        </div>
        <div class="flex gap-3">
          {socialLinks.map(({ href, label, Icon }) => (
            <a href={href} class="footer-social-icon" aria-label={label}>
              <Icon class="w-5 h-5" />
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        {copyrightText}
      </p>
      <div class="footer-legal">
        {legalLinks.map((link, index) => (
          <>
            {index > 0 && <span>|</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-background);
    padding: 96px 32px 32px;
    position: relative;
  }

  .footer-inner {
    max-width: 1320px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid rgba(164, 178, 147, 0.2);
  }

  .footer-brand {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .footer-brand-sub {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary-lighter);
    margin-bottom: 20px;
  }

  .footer-tag {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(247, 242, 231, 0.75);
    max-width: 36ch;
    margin: 0;
  }

  .footer-col h4 {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary-lighter);
    margin: 0 0 24px 0;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-col li {
    margin-bottom: 12px;
  }

  .footer-col a {
    font-size: 14px;
    color: rgba(247, 242, 231, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--color-background);
  }

  .footer-contact li {
    font-size: 14px;
    color: rgba(247, 242, 231, 0.8);
  }

  .footer-contact a {
    color: rgba(247, 242, 231, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-contact a:hover {
    color: var(--color-primary-lighter);
  }

  /* Social */
  .footer-social {
    padding: 32px 0;
    border-bottom: 1px solid rgba(164, 178, 147, 0.2);
  }

  .footer-social-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-social-label {
    font-size: 12px;
    color: rgba(247, 242, 231, 0.6);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(247, 242, 231, 0.1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-background);
    transition: background 0.2s, transform 0.2s;
  }

  .footer-social-icon:hover {
    background: var(--color-primary-lighter);
    color: var(--color-primary-darker);
    transform: scale(1.05);
  }

  /* Bottom */
  .footer-bottom {
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: rgba(247, 242, 231, 0.5);
  }

  .footer-copyright {
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .footer-legal a {
    color: rgba(247, 242, 231, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-legal a:hover {
    color: var(--color-primary-lighter);
  }

  @media (max-width: 960px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }

    .footer-social-row,
    .footer-bottom {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
