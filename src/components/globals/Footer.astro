---
import { MapPin, Phone, Mail, Clock, Facebook, Instagram, Twitter, Youtube } from 'lucide-astro';
import {
  getFooterContentWithFallback,
  normalizeSiteLanguage,
} from '../../lib/directus';

const currentYear = new Date().getFullYear();
const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const footerContent = await getFooterContentWithFallback(language);

const formatFooterText = (value?: string) =>
  (value ?? '').replace(/\r\n/g, '\n').split('\n');

const copyrightText = (footerContent.copyright_text ?? 'Journal Ocean ©{year}. All rights reserved.').replace(
  '{year}',
  String(currentYear)
);

const aboutLinks = [
  { label: footerContent.about_link_1_label ?? 'Profil Journal Ocean', href: footerContent.about_link_1_href ?? '/profil' },
  { label: footerContent.about_link_2_label ?? 'Visi & Misi', href: footerContent.about_link_2_href ?? '/profil#visi-misi' },
  { label: footerContent.about_link_3_label ?? 'Struktur', href: footerContent.about_link_3_href ?? '/profil#struktur' },
].filter((item) => item.label);

const programLinks = [
  { label: footerContent.program_link_1_label ?? 'Sosial', href: footerContent.program_link_1_href ?? '/program#sosial' },
  { label: footerContent.program_link_2_label ?? 'Kemanusiaan', href: footerContent.program_link_2_href ?? '/program#kemanusiaan' },
  { label: footerContent.program_link_3_label ?? 'Keagamaan', href: footerContent.program_link_3_href ?? '/program#keagamaan' },
].filter((item) => item.label);

const normalizeExternalUrl = (value?: string) => {
  if (!value) return '';
  if (value === '#' || value.startsWith('/') || /^(https?:|mailto:|tel:)/i.test(value)) return value;
  return `https://${value}`;
};

const socialLinks = [
  { label: footerContent.facebook_label, href: normalizeExternalUrl(footerContent.facebook_url), Icon: Facebook },
  { label: footerContent.instagram_label, href: normalizeExternalUrl(footerContent.instagram_url), Icon: Instagram },
  { label: footerContent.twitter_label, href: normalizeExternalUrl(footerContent.twitter_url), Icon: Twitter },
  { label: footerContent.youtube_label, href: normalizeExternalUrl(footerContent.youtube_url), Icon: Youtube },
].filter((item) => item.label && item.href);

const legalLinks = [
  { label: footerContent.privacy_label ?? 'Kebijakan Privasi', href: footerContent.privacy_href ?? '#' },
  { label: footerContent.terms_label ?? 'Syarat & Ketentuan', href: footerContent.terms_href ?? '#' },
].filter((item) => item.label);
---

<footer class="bg-brand-primary px-8 pt-24 pb-8 text-brand-background max-[960px]:px-6">
  <div class="mx-auto max-w-[1320px]">
    <div class="mb-16 grid grid-cols-[1.4fr_1fr_1fr_1fr] gap-16 border-b border-brand-primary-lighter/20 pb-16 max-[960px]:grid-cols-2 max-[960px]:gap-12">
      <div>
        <div class="mb-2 font-serif text-[36px] font-semibold tracking-[-0.02em]">{footerContent.brand_name ?? 'Journal Ocean'}</div>
        <div class="mb-5 text-[11px] font-medium uppercase tracking-[0.2em] text-brand-primary-lighter">{footerContent.brand_subtitle ?? 'Jurnal · Sejak 2014'}</div>
        <p class="m-0 max-w-[36ch] text-sm leading-[1.6] text-brand-background/75">{footerContent.tagline}</p>
      </div>

      <div>
        <h4 class="m-0 mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-primary-lighter">{footerContent.about_title ?? 'Tentang'}</h4>
        <ul class="m-0 list-none p-0">
          {aboutLinks.map((link) => (
            <li class="mb-3"><a href={link.href} class="text-sm text-brand-background/80 no-underline transition-colors hover:text-brand-background">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="m-0 mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-primary-lighter">{footerContent.program_title ?? 'Program'}</h4>
        <ul class="m-0 list-none p-0">
          {programLinks.map((link) => (
            <li class="mb-3"><a href={link.href} class="text-sm text-brand-background/80 no-underline transition-colors hover:text-brand-background">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="m-0 mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-primary-lighter">{footerContent.contact_title ?? 'Hubungi'}</h4>
        <ul class="m-0 list-none p-0 text-sm text-brand-background/80">
          <li class="mb-3 flex items-start gap-2">
            <MapPin class="mt-1 h-4 w-4 shrink-0" />
            <a href={footerContent.address_href ?? '#'} class="text-brand-background/80 no-underline transition-colors hover:text-brand-primary-lighter">
              {formatFooterText(footerContent.address_text).map((line, index) => (
                <>{index > 0 && <br />}{line}</>
              ))}
            </a>
          </li>
          <li class="mb-3 flex items-center gap-2">
            <Phone class="h-4 w-4 shrink-0" />
            <a href={footerContent.phone_href ?? '#'} class="text-brand-background/80 no-underline transition-colors hover:text-brand-primary-lighter">{footerContent.phone_label}</a>
          </li>
          <li class="mb-3 flex items-center gap-2">
            <Mail class="h-4 w-4 shrink-0" />
            <a href={footerContent.email_href ?? '#'} class="text-brand-background/80 no-underline transition-colors hover:text-brand-primary-lighter">{footerContent.email_label}</a>
          </li>
          <li class="flex items-center gap-2">
            <Clock class="h-4 w-4 shrink-0" />
            <span>
              {formatFooterText(footerContent.office_hours_text).map((line, index) => (
                <>{index > 0 && <br />}{line}</>
              ))}
            </span>
          </li>
        </ul>
      </div>
    </div>

    <div class="flex items-center justify-between border-b border-brand-primary-lighter/20 py-8 max-[960px]:flex-col max-[960px]:gap-4">
      <div class="flex items-center gap-2">
        <span class="text-xs uppercase tracking-[0.1em] text-brand-background/60">{footerContent.social_label ?? 'Ikuti Kami:'}</span>
      </div>
      <div class="flex gap-3">
        {socialLinks.map(({ href, label, Icon }) => (
          <a href={href} class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-background/10 text-brand-background transition-all hover:scale-105 hover:bg-brand-primary-lighter hover:text-brand-primary-darker" aria-label={label}>
            <Icon class="h-5 w-5" />
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center justify-between pt-8 text-xs text-brand-background/50 max-[960px]:flex-col max-[960px]:gap-4">
      <p class="m-0">{copyrightText}</p>
      <div class="flex items-center gap-3">
        {legalLinks.map((link, index) => (
          <>
            {index > 0 && <span>|</span>}
            <a href={link.href} class="text-brand-background/50 no-underline transition-colors hover:text-brand-primary-lighter">{link.label}</a>
          </>
        ))}
      </div>
    </div>
  </div>
</footer>
