---
import {
  getSocialProgramContentWithFallback,
  normalizeSiteLanguage,
} from '../../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const socialProgram = await getSocialProgramContentWithFallback(language);

const sectionTitle =
  socialProgram.title;
const sectionSubtitle =
  socialProgram.subtitle;

const programFeature = {
  eyebrow: socialProgram.program_eyebrow,
  category: socialProgram.category,
  title: socialProgram.program_title,
  desc:
    socialProgram.program_desc,
  image: socialProgram.image,
  imageAlt:
    socialProgram.image_alt ?? socialProgram.program_title,
  stat: {
    num: socialProgram.stat_num,
    label: socialProgram.stat_label,
  },
  bullets: (socialProgram.program_bullets ?? [])
    .map((item) => item.text)
    .filter(Boolean),
};

const programCards = (socialProgram.list_program ?? []).map((item, idx) => ({
  index: idx + 1,
  icon: item.icon ?? item.title?.slice(0, 1) ?? 'J',
  title: item.title ?? '',
  desc: item.desc ?? '',
  image: item.image,
  imageAlt: item.image_alt ?? item.title,
}));

const spotlightCards = programCards.slice(0, 2);
const archiveCards = programCards.slice(2);
const hasArchiveCards = archiveCards.length > 0;
---

<section
  id="sosial"
  aria-labelledby="sosial-title"
  class="bg-brand-background px-4 py-18 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
>
  <div class="mx-auto max-w-7xl">
    <header
      class="mb-10 grid gap-5 border-b border-brand-border pb-10 sm:mb-12 sm:gap-6 sm:pb-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-end lg:gap-14 lg:pb-16"
    >
      <div>
        <div
          class="mb-4 inline-flex items-center gap-3 text-[10px] font-medium uppercase tracking-[0.22em] text-brand-primary sm:text-[11px]"
        >
          <span class="h-px w-7 bg-brand-primary sm:w-8"></span>
          <span>{programFeature.category}</span>
        </div>
        <h2
          id="sosial-title"
          class="m-0 max-w-[13ch] font-serif text-[clamp(34px,9vw,72px)] font-normal leading-[0.98] tracking-[-0.03em] text-brand-ink [&_em]:font-light [&_em]:italic [&_em]:text-brand-primary"
        >
          <Fragment set:html={sectionTitle} />
        </h2>
      </div>
      <div class="grid gap-4 sm:gap-5">
        <p
          class="m-0 max-w-[60ch] text-[14px] leading-6 text-brand-ink-soft sm:text-[15px] sm:leading-7 lg:text-[16px]"
        >
          {sectionSubtitle}
        </p>
        <div
          class="flex flex-wrap items-center gap-3 text-[10px] uppercase tracking-[0.18em] text-brand-primary/75 sm:text-[11px]"
        >
          <span
            class="rounded-full border border-brand-border bg-brand-surface px-3 py-1.5"
          >
            {programFeature.eyebrow}
          </span>
          <span
            class="rounded-full border border-brand-border bg-brand-surface px-3 py-1.5"
          >
            {programCards.length}
          </span>
        </div>
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-[1.18fr_0.82fr] lg:items-stretch">
      <article
        class="overflow-hidden rounded-[28px] border border-brand-border bg-brand-surface shadow-[0_22px_60px_rgba(42,46,37,0.08)]"
      >
        <div class="grid lg:min-h-170 lg:grid-cols-[1.06fr_0.94fr]">
          <div class="relative min-h-75 sm:min-h-95 lg:min-h-full">
            <img
              src={programFeature.image}
              alt={programFeature.imageAlt}
              class="absolute inset-0 h-full w-full object-cover saturate-[0.86]"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-black/60 via-black/18 to-transparent"
            >
            </div>
            <div
              class="absolute inset-x-4 top-4 flex items-start justify-between gap-3 sm:inset-x-7 sm:top-7 sm:gap-4"
            >
              <div
                class="rounded-full border border-white/30 bg-black/20 px-3 py-1.5 text-[9px] font-medium uppercase tracking-[0.18em] text-white backdrop-blur-sm sm:px-4 sm:py-2 sm:text-[10px]"
              >
                {programFeature.eyebrow}
              </div>
              <div
                class="rounded-[18px] border border-white/20 bg-white/12 px-3 py-2.5 text-right text-white backdrop-blur-md sm:rounded-[20px] sm:px-5 sm:py-3"
              >
                <div class="font-serif text-[24px] leading-none sm:text-[38px]">
                  {programFeature.stat.num}
                </div>
                <div
                  class="mt-1 max-w-[12ch] text-[9px] uppercase tracking-[0.16em] text-white/80 sm:text-[10.5px]"
                >
                  {programFeature.stat.label}
                </div>
              </div>
            </div>
          </div>

          <div
            class="flex h-full flex-col justify-between px-5 py-6 sm:px-8 sm:py-9"
          >
            <div>
              <div
                class="mb-3 text-[10px] font-medium uppercase tracking-[0.2em] text-brand-primary sm:text-[11px]"
              >
                Program Fokus
              </div>
              <h3
                class="m-0 max-w-[14ch] font-serif text-[clamp(28px,6vw,46px)] font-normal leading-[1.02] tracking-[-0.02em] text-brand-ink"
              >
                {programFeature.title}
              </h3>
              <p
                class="mt-4 text-[14px] leading-6 text-brand-ink-soft sm:mt-5 sm:text-base sm:leading-7"
              >
                {programFeature.desc}
              </p>
            </div>

            <div
              class="mt-7 grid gap-4 border-t border-brand-border pt-5 sm:mt-8 sm:gap-5 sm:pt-6"
            >
              <div class="flex items-center justify-between gap-3">
                <div
                  class="text-[10px] font-medium uppercase tracking-[0.18em] text-brand-primary sm:text-[11px]"
                >
                  Garis Program
                </div>
                <div
                  class="font-mono text-[10px] uppercase tracking-[0.16em] text-brand-primary/70"
                >
                  01-{String(programFeature.bullets.length).padStart(2, '0')}
                </div>
              </div>
              <ul class="m-0 grid list-none gap-2.5 p-0 sm:gap-3">
                {
                  programFeature.bullets.map((bullet, idx) => (
                    <li class="grid grid-cols-[auto_1fr] items-start gap-3 rounded-[18px] bg-brand-background/80 px-3.5 py-3 sm:rounded-2xl sm:px-4">
                      <span class="pt-0.5 font-mono text-[10px] tracking-[0.14em] text-brand-primary sm:text-[11px]">
                        {String(idx + 1).padStart(2, '0')}
                      </span>
                      <span class="text-[13.5px] leading-6 text-brand-ink sm:text-[14.5px]">
                        {bullet}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </article>

      <div class="grid gap-5 sm:gap-6">
        {
          spotlightCards.map((program, idx) => (
            <article class="group grid overflow-hidden rounded-3xl border border-brand-border bg-brand-surface shadow-[0_16px_42px_rgba(42,46,37,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_20px_46px_rgba(42,46,37,0.08)] sm:grid-cols-[0.95fr_1.05fr]">
              <div class="relative min-h-55 overflow-hidden sm:min-h-0">
                <img
                  src={program.image}
                  alt={program.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover saturate-[0.84] transition duration-700 group-hover:scale-[1.04]"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/35 via-transparent to-transparent" />
                <div class="absolute inset-x-3 top-3 flex items-center justify-between gap-3 sm:inset-x-4 sm:top-4">
                  <span class="rounded-full bg-brand-background px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-brand-primary">
                    {String(idx + 1).padStart(2, '0')}
                  </span>
                  <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-black/20 font-serif text-lg italic text-white backdrop-blur-sm">
                    {program.icon}
                  </span>
                </div>
              </div>

              <div class="flex flex-col justify-between px-4 py-4 sm:px-5 sm:py-5">
                <div>
                  <div class="mb-2 text-[10px] uppercase tracking-[0.18em] text-brand-primary/75">
                    Sorotan Program
                  </div>
                  <h4 class="m-0 font-serif text-[22px] leading-[1.06] tracking-[-0.02em] text-brand-ink sm:text-[24px]">
                    {program.title}
                  </h4>
                  <p class="mt-3 text-[13.5px] leading-6 text-brand-ink-soft sm:text-[14px]">
                    {program.desc}
                  </p>
                </div>
                <div class="mt-5 border-t border-brand-border pt-4 font-mono text-[10px] uppercase tracking-[0.16em] text-brand-primary/70">
                  {String(program.index).padStart(2, '0')}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    {
      hasArchiveCards && (
        <div class="mt-6 rounded-[28px] border border-brand-border bg-brand-surface/82 p-4 shadow-[0_16px_42px_rgba(42,46,37,0.05)] sm:mt-8 sm:p-5 lg:p-6">
          <div class="grid gap-4 lg:grid-cols-2">
            <div class="grid gap-4">
              {archiveCards.slice(0, 2).map((program, idx) => (
                <article class="group grid overflow-hidden rounded-3xl border border-brand-border bg-brand-background/74 transition duration-300 hover:border-brand-primary/30 hover:bg-brand-surface sm:grid-cols-[240px_1fr]">
                  <div class="relative aspect-4/3 overflow-hidden sm:aspect-auto sm:h-full">
                    <img
                      src={program.image}
                      alt={program.imageAlt}
                      class="absolute inset-0 h-full w-full object-cover saturate-[0.84] transition duration-700 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    <div class="absolute left-3 top-3 rounded-full bg-brand-surface px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-brand-primary sm:left-4 sm:top-4">
                      {String(program.index).padStart(2, '0')}
                    </div>
                  </div>
                  <div class="flex flex-col justify-center px-4 py-4 sm:px-5 sm:py-5">
                    <div class="mb-3 flex items-center gap-3">
                      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-primary/12 font-serif text-lg italic text-brand-primary">
                        {program.icon}
                      </span>
                      <h4 class="m-0 font-serif text-[20px] leading-[1.08] tracking-[-0.02em] text-brand-ink sm:text-[22px]">
                        {program.title}
                      </h4>
                    </div>
                    <p class="m-0 text-[13.5px] leading-6 text-brand-ink-soft sm:text-[14px]">
                      {program.desc}
                    </p>
                  </div>
                </article>
              ))}
            </div>

            <div class="grid gap-3.5 sm:gap-4">
              {archiveCards.slice(2).map((program) => (
                <article class="group grid overflow-hidden rounded-3xl border border-brand-border bg-brand-background/74 transition duration-300 hover:border-brand-primary/30 hover:bg-brand-surface sm:grid-cols-[240px_1fr]">
                  <div class="relative aspect-4/3 overflow-hidden sm:aspect-auto sm:h-full">
                    <img
                      src={program.image}
                      alt={program.imageAlt}
                      class="absolute inset-0 h-full w-full object-cover saturate-[0.84] transition duration-700 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    <div class="absolute left-3 top-3 rounded-full bg-brand-surface px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.14em] text-brand-primary sm:left-3.5 sm:top-3.5">
                      {String(program.index).padStart(2, '0')}
                    </div>
                  </div>
                  <div class="flex flex-col justify-center px-4 py-4 sm:px-5 sm:py-4">
                    <div class="mb-2.5 flex items-center gap-3">
                      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-primary/12 font-serif text-base italic text-brand-primary sm:h-10 sm:w-10 sm:text-lg">
                        {program.icon}
                      </span>
                      <h4 class="m-0 font-serif text-[18px] leading-[1.08] tracking-[-0.02em] text-brand-ink sm:text-[19px]">
                        {program.title}
                      </h4>
                    </div>
                    <p class="m-0 text-[13px] leading-6 text-brand-ink-soft sm:text-[13.5px]">
                      {program.desc}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>
