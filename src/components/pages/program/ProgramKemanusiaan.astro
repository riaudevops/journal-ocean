---
import {
  getHumanitarianProgramContentWithFallback,
  normalizeSiteLanguage,
} from '../../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const humanitarianProgram =
  await getHumanitarianProgramContentWithFallback(language);

const sectionTitle = humanitarianProgram.title;
const sectionSubtitle = humanitarianProgram.subtitle;

const programFeature = {
  eyebrow: humanitarianProgram.program_eyebrow,
  category: humanitarianProgram.category,
  title: humanitarianProgram.program_title,
  desc: humanitarianProgram.program_desc,
  image: humanitarianProgram.image,
  imageAlt: humanitarianProgram.image_alt ?? humanitarianProgram.program_title,
  stat: {
    num: humanitarianProgram.stat_num,
    label: humanitarianProgram.stat_label,
  },
  bullets: (humanitarianProgram.program_bullets ?? [])
    .map((item) => item.text)
    .filter(Boolean),
};

const programCards = (humanitarianProgram.list_program ?? []).map((item) => ({
  icon: item.icon ?? item.title?.slice(0, 1),
  title: item.title ?? '',
  desc: item.desc ?? '',
  image: item.image,
  imageAlt: item.image_alt ?? item.title,
}));
---

<section
  id="kemanusiaan"
  aria-labelledby="kemanusiaan-title"
  class="bg-brand-sand/45 px-4 py-18 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
>
  <div class="mx-auto max-w-7xl">
    <header
      class="mb-10 grid gap-5 border-b border-brand-border pb-10 sm:mb-12 sm:gap-6 sm:pb-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-end lg:gap-14 lg:pb-16"
    >
      <div>
        <div
          class="mb-4 inline-flex items-center gap-3 text-[10px] font-medium uppercase tracking-[0.22em] text-brand-rust sm:text-[11px]"
        >
          <span class="h-px w-7 bg-brand-rust sm:w-8"></span>
          <span>{programFeature.category}</span>
        </div>
        <h2
          id="kemanusiaan-title"
          class="m-0 max-w-[12ch] font-serif text-[clamp(34px,9vw,72px)] font-normal leading-[0.98] tracking-[-0.03em] text-brand-ink [&_em]:font-light [&_em]:italic [&_em]:text-brand-rust"
        >
          <Fragment set:html={sectionTitle} />
        </h2>
      </div>
      <p
        class="m-0 max-w-[60ch] text-[14px] leading-6 text-brand-ink-soft sm:text-[15px] sm:leading-7 lg:text-[16px]"
      >
        {sectionSubtitle}
      </p>
    </header>

    <div class="grid gap-5 sm:gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:gap-6">
      <aside
        class="rounded-3xl border border-brand-ink/10 bg-brand-primary px-5 py-6 text-brand-background shadow-[0_20px_60px_rgba(42,46,37,0.12)] sm:rounded-[28px] sm:px-7 sm:py-7 lg:sticky lg:top-24"
      >
        <div
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-3 py-1.5 text-[10px] uppercase tracking-[0.18em] text-white/82"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-brand-rust"></span>
          <span>{programFeature.eyebrow}</span>
        </div>

        <div class="grid gap-5 border-b border-white/12 pb-5 sm:gap-6 sm:pb-6">
          <div>
            <div class="font-serif text-[44px] leading-none sm:text-[58px]">
              {programFeature.stat.num}
            </div>
            <div
              class="mt-2 text-[10px] uppercase tracking-[0.18em] text-white/70"
            >
              {programFeature.stat.label}
            </div>
          </div>
          <h3
            class="m-0 max-w-[12ch] font-serif text-[clamp(26px,6vw,42px)] font-normal leading-[1.02] tracking-[-0.03em] text-white"
          >
            {programFeature.title}
          </h3>
          <p
            class="m-0 text-[14px] leading-6 text-white/76 sm:text-[15px] sm:leading-7"
          >
            {programFeature.desc}
          </p>
        </div>

        <ul class="mt-5 grid list-none gap-3 p-0 sm:mt-6">
          {
            programFeature.bullets.map((bullet, idx) => (
              <li class="grid grid-cols-[auto_1fr] items-start gap-3 rounded-[18px] border border-white/10 bg-white/6 px-3.5 py-3 sm:px-4">
                <span class="pt-0.5 font-mono text-[10px] tracking-[0.14em] text-white/68">
                  R{idx + 1}
                </span>
                <span class="text-[13.5px] leading-6 text-white/84 sm:text-[14px]">
                  {bullet}
                </span>
              </li>
            ))
          }
        </ul>
      </aside>

      <div class="grid gap-5 sm:gap-6">
        {
          programFeature.image && (
            <article class="overflow-hidden rounded-3xl border border-brand-border bg-brand-surface shadow-[0_18px_48px_rgba(42,46,37,0.08)] sm:rounded-[28px]">
              <div class="relative min-h-75 sm:min-h-90 lg:min-h-105">
                <img
                  src={programFeature.image}
                  alt={programFeature.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover saturate-[0.82]"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/18 to-transparent" />
                <div class="absolute inset-x-4 bottom-4 sm:inset-x-6 sm:bottom-6">
                  <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[9px] uppercase tracking-[0.18em] text-white backdrop-blur-sm sm:text-[10px]">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-rust" />
                    <span>{programFeature.category}</span>
                  </div>
                </div>
              </div>
            </article>
          )
        }

        <div class="grid gap-4 xl:grid-cols-3">
          {
            programCards
              .filter((p) => p.image)
              .map((program, idx) => (
                <article class="group overflow-hidden rounded-3xl border border-brand-border bg-brand-surface transition duration-300 hover:-translate-y-1 hover:shadow-[0_16px_38px_rgba(42,46,37,0.08)] sm:rounded-3xl">
                  <div class="relative aspect-4/3 overflow-hidden">
                    <img
                      src={program.image}
                      alt={program.imageAlt}
                      class="h-full w-full object-cover saturate-[0.84] transition duration-700 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    <div class="absolute inset-x-3 top-3 flex items-start justify-between gap-3 sm:inset-x-4 sm:top-4">
                      <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-black/25 font-serif text-lg italic text-white backdrop-blur-sm">
                        {program.icon}
                      </span>
                      <span class="rounded-full bg-brand-background px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.16em] text-brand-rust">
                        {String(idx + 1).padStart(2, '0')}
                      </span>
                    </div>
                  </div>
                  <div class="px-4 py-4 sm:px-5 sm:py-5">
                    <h4 class="m-0 font-serif text-[20px] leading-[1.08] tracking-[-0.02em] text-brand-ink">
                      {program.title}
                    </h4>
                    <p class="mt-3 text-[13.5px] leading-6 text-brand-ink-soft sm:text-[14px]">
                      {program.desc}
                    </p>
                  </div>
                </article>
              ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
