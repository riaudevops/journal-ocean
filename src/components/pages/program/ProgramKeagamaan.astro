---
import {
  getReligiousProgramContentWithFallback,
  normalizeSiteLanguage,
} from '../../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const religiousProgram = await getReligiousProgramContentWithFallback(language);

const sectionTitle = religiousProgram.title;
const sectionSubtitle = religiousProgram.subtitle;

const programFeature = {
  eyebrow: religiousProgram.program_eyebrow,
  category: religiousProgram.category,
  title: religiousProgram.program_title,
  desc: religiousProgram.program_desc,
  image: religiousProgram.image,
  imageAlt: religiousProgram.image_alt ?? religiousProgram.program_title,
  stat: {
    num: religiousProgram.stat_num,
    label: religiousProgram.stat_label,
  },
  bullets: (religiousProgram.program_bullets ?? [])
    .map((item) => item.text)
    .filter(Boolean),
};

const programCards = (religiousProgram.list_program ?? []).map((item) => ({
  icon: item.icon ?? item.title?.slice(0, 1),
  title: item.title ?? '',
  desc: item.desc ?? '',
  image: item.image,
  imageAlt: item.image_alt ?? item.title,
}));

const featureCards = programCards.filter((p) => p.image).slice(0, 2);
const archiveCards = programCards.filter((p) => p.image).slice(2);
---

<section
  id="keagamaan"
  aria-labelledby="keagamaan-title"
  class="bg-brand-background px-4 py-18 sm:px-6 sm:py-20 lg:px-8 lg:py-28"
>
  <div class="mx-auto max-w-7xl">
    <header class="mx-auto mb-10 max-w-4xl text-center sm:mb-12 lg:mb-16">
      <div
        class="mb-4 inline-flex items-center gap-3 text-[10px] font-medium uppercase tracking-[0.22em] text-brand-primary sm:text-[11px]"
      >
        <span class="h-px w-7 bg-brand-primary sm:w-8"></span>
        <span>{programFeature.category}</span>
        <span class="h-px w-7 bg-brand-primary sm:w-8"></span>
      </div>
      <h2
        id="keagamaan-title"
        class="m-0 font-serif text-[clamp(34px,9vw,72px)] font-normal leading-[0.98] tracking-[-0.03em] text-brand-ink [&_em]:font-light [&_em]:italic [&_em]:text-brand-primary"
      >
        <Fragment set:html={sectionTitle} />
      </h2>
      <p
        class="mx-auto mt-4 max-w-[60ch] text-[14px] leading-6 text-brand-ink-soft sm:mt-5 sm:text-[15px] sm:leading-7 lg:text-[16px]"
      >
        {sectionSubtitle}
      </p>
    </header>

    <article
      class="overflow-hidden rounded-3xl border border-brand-border bg-brand-surface shadow-[0_18px_48px_rgba(42,46,37,0.08)] sm:rounded-[30px]"
    >
      <div class="grid lg:grid-cols-[0.9fr_1.1fr]">
        <div
          class="border-b border-brand-border px-5 py-6 sm:px-8 sm:py-8 lg:border-b-0 lg:border-r lg:px-9 lg:py-10"
        >
          <div
            class="mb-3 text-[10px] font-medium uppercase tracking-[0.2em] text-brand-primary sm:text-[11px]"
          >
            {programFeature.eyebrow}
          </div>
          <h3
            class="m-0 max-w-[13ch] font-serif text-[clamp(26px,6vw,46px)] font-normal leading-[1.03] tracking-[-0.03em] text-brand-ink"
          >
            {programFeature.title}
          </h3>
          <p
            class="mt-4 text-[14px] leading-6 text-brand-ink-soft sm:mt-5 sm:text-base sm:leading-7"
          >
            {programFeature.desc}
          </p>

          <div
            class="mt-6 grid gap-3 border-t border-brand-border pt-5 sm:mt-8 sm:pt-6"
          >
            <div
              class="rounded-[18px] bg-brand-background px-4 py-4 sm:rounded-[20px]"
            >
              <div
                class="font-serif text-[38px] leading-none text-brand-primary sm:text-[52px]"
              >
                {programFeature.stat.num}
              </div>
              <div
                class="mt-2 text-[10px] uppercase tracking-[0.18em] text-brand-primary/75"
              >
                {programFeature.stat.label}
              </div>
            </div>
            <ul class="m-0 grid list-none gap-2.5 p-0 sm:gap-3">
              {
                programFeature.bullets.map((bullet, idx) => (
                  <li class="grid grid-cols-[auto_1fr] items-start gap-3 rounded-[18px] border border-brand-border/80 bg-brand-surface px-3.5 py-3 sm:px-4">
                    <span class="pt-0.5 font-mono text-[10px] tracking-[0.14em] text-brand-primary sm:text-[11px]">
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <span class="text-[13.5px] leading-6 text-brand-ink sm:text-[14px]">
                      {bullet}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="grid gap-0 lg:grid-rows-[minmax(320px,420px)_auto]">
          {
            programFeature.image && (
              <div class="relative min-h-70 border-b border-brand-border sm:min-h-85">
                <img
                  src={programFeature.image}
                  alt={programFeature.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover saturate-[0.82]"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/45 via-black/10 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-7">
                  <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[9px] uppercase tracking-[0.18em] text-white backdrop-blur-sm sm:text-[10px]">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-primary-lighter" />
                    <span>{programFeature.category}</span>
                  </div>
                </div>
              </div>
            )
          }

          <div class="grid gap-4 p-4 sm:p-5 xl:grid-cols-2">
            {
              featureCards.map((program, idx) => (
                <article class="group overflow-hidden rounded-[22px] border border-brand-border bg-brand-background/72 transition duration-300 hover:-translate-y-1 hover:shadow-[0_16px_36px_rgba(42,46,37,0.08)]">
                  <div class="relative aspect-4/3 overflow-hidden">
                    <img
                      src={program.image}
                      alt={program.imageAlt}
                      class="h-full w-full object-cover saturate-[0.84] transition duration-700 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    <div class="absolute left-3 top-3 rounded-full bg-brand-surface px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-brand-primary sm:left-4 sm:top-4">
                      {String(idx + 1).padStart(2, '0')}
                    </div>
                  </div>
                  <div class="px-4 py-4 sm:px-5 sm:py-5">
                    <div class="mb-3 flex items-center gap-3">
                      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary/12 font-serif text-lg italic text-brand-primary">
                        {program.icon}
                      </span>
                      <h4 class="m-0 font-serif text-[20px] leading-[1.08] tracking-[-0.02em] text-brand-ink">
                        {program.title}
                      </h4>
                    </div>
                    <p class="m-0 text-[13.5px] leading-6 text-brand-ink-soft sm:text-[14px]">
                      {program.desc}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </article>

    {
      archiveCards.length > 0 && (
        <div class="mt-6 rounded-3xl border border-brand-border bg-brand-surface/75 p-4 sm:mt-8 sm:rounded-[28px] sm:p-5 lg:p-6">
          <div class="grid gap-3 sm:gap-4 lg:grid-cols-2">
            {archiveCards.map((program, idx) => (
              <article class="grid gap-4 rounded-[20px] border border-brand-border bg-brand-background/72 p-4 sm:grid-cols-[160px_1fr] sm:rounded-[22px] sm:p-5">
                <div class="relative aspect-4/3 overflow-hidden rounded-2xl sm:h-full sm:min-h-35 sm:aspect-auto">
                  <img
                    src={program.image}
                    alt={program.imageAlt}
                    class="h-full w-full object-cover saturate-[0.84]"
                    loading="lazy"
                  />
                  <div class="absolute left-3 top-3 rounded-full bg-brand-surface px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-brand-primary">
                    {String(idx + 3).padStart(2, '0')}
                  </div>
                </div>
                <div class="flex flex-col justify-between gap-3">
                  <div>
                    <div class="mb-3 flex items-center gap-3">
                      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary/12 font-serif text-lg italic text-brand-primary">
                        {program.icon}
                      </span>
                      <h4 class="m-0 font-serif text-[18px] leading-[1.08] tracking-[-0.02em] text-brand-ink sm:text-[20px]">
                        {program.title}
                      </h4>
                    </div>
                    <p class="m-0 text-[13px] leading-6 text-brand-ink-soft sm:text-[13.5px]">
                      {program.desc}
                    </p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
