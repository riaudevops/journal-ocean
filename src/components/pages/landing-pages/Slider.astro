---
import {
  getHeroSlides,
  directusAssetUrl,
  normalizeSiteLanguage,
} from '../../../lib/directus';
import type { HeroSlide } from '../../../lib/directus';

export type Slide = HeroSlide;

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const slides: Slide[] = await getHeroSlides(language);
const totalSlides = slides.length;
const heroTag = language === 'en' ? 'Core Value' : 'Nilai Utama';

const formatSlideNumber = (
  value: string | number | undefined,
  index: number
) => {
  const raw = String(value ?? index + 1).trim();
  return raw.padStart(2, '0');
};

const resolvedSlides = slides.map((s, index) => ({
  ...s,
  number: formatSlideNumber(s.number, index),
  image: directusAssetUrl(s.image) || s.image,
}));
---

<section
  id="hero"
  class="relative h-[88vh] min-h-160 w-full overflow-hidden bg-brand-primary text-brand-background max-[640px]:h-auto max-[640px]:min-h-dvh"
  aria-roledescription="carousel"
>
  <div
    class="absolute inset-0 flex transition-transform duration-1000 [cubic-bezier(0.65,0,0.35,1)]"
    id="heroTrack"
  >
    {
      resolvedSlides.map((slide) => (
        <div
          class="relative flex h-full min-w-full shrink-0 items-center"
          role="group"
          aria-roledescription="slide"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-cover bg-center brightness-[0.7] saturate-[0.7]"
            style={`background-image: url('${slide.image}');`}
          />
          <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(74,93,63,0.85)_0%,rgba(42,46,37,0.65)_100%)]" />

          <div class="relative z-2 mx-auto grid w-full max-w-7xl grid-cols-[1.4fr_1fr] items-center gap-16 px-8 max-[960px]:grid-cols-1 max-[960px]:gap-8 max-[960px]:px-6 max-[640px]:px-5 max-[640px]:pt-22 max-[640px]:pb-34">
            <div>
              <div class="mb-6 font-serif text-[clamp(80px,12vw,160px)] font-light italic leading-none tracking-[-0.04em] opacity-40 max-[640px]:text-[clamp(40px,10vw,72px)]">
                {slide.number}
              </div>
              <div class="mb-5 inline-flex items-center gap-2.5 text-[11.5px] font-medium uppercase tracking-[0.2em] text-brand-primary-lighter before:h-px before:w-7 before:bg-brand-primary-lighter before:content-['']">
                {heroTag}
              </div>
              <h1
                class="m-0 max-w-[18ch] font-serif text-[clamp(36px,4.5vw,60px)] font-normal leading-[1.08] tracking-[-0.02em] wrap-anywhere [word-break:break-word] max-[640px]:max-w-full max-[640px]:text-[clamp(28px,8vw,42px)] max-[640px]:line-clamp-4 [&_em]:font-light [&_em]:italic [&_em]:text-brand-primary-lighter"
                set:html={slide.headline}
              />
            </div>

            <div class="border-l border-brand-background/25 pl-8 max-[960px]:border-l-0 max-[960px]:border-t max-[960px]:border-brand-background/25 max-[960px]:pl-0 max-[960px]:pt-6 max-[640px]:pt-5">
              <p class="m-0 mb-5 max-w-[28ch] font-serif text-lg italic leading-normal text-brand-background/85 max-[640px]:max-w-full max-[640px]:text-[16px]">
                {slide.quote}
              </p>
              <p class="m-0 text-[11.5px] font-medium uppercase tracking-[0.15em] text-brand-primary-lighter">
                — {slide.quote_attr ?? 'Journal Ocean'}
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div
    class="absolute bottom-8 left-0 right-0 z-3 mx-auto flex w-full max-w-7xl items-center gap-6 px-8 max-[960px]:bottom-6 max-[640px]:bottom-4 max-[640px]:gap-4 max-[640px]:px-5"
  >
    <span
      class="font-mono text-xs tracking-wider text-brand-primary-lighter"
      id="heroCounter">01 / {String(totalSlides).padStart(2, '0')}</span
    >
    <div class="flex flex-1 gap-1.5" id="heroProgress"></div>
  </div>
</section>

<script define:vars={{ totalSlides }}>
  (function () {
    const track = document.getElementById('heroTrack');
    const hero = document.getElementById('hero');
    const progress = document.getElementById('heroProgress');
    const counter = document.getElementById('heroCounter');
    if (!track || !progress || !counter || !hero) return;

    const slides = track.querySelectorAll('[role="group"]');
    const total = slides.length || totalSlides;
    if (total <= 0) return;

    for (let i = 0; i < total; i++) {
      const d = document.createElement('div');
      d.className =
        'flex-1 h-[2px] relative overflow-hidden rounded-[2px] bg-brand-background/20';
      if (i === 0) d.classList.add('active');
      progress.appendChild(d);
    }

    let current = 0;
    let timer = null;

    const go = (n) => {
      current = (n + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
      Array.from(progress.children).forEach((el, idx) => {
        el.classList.toggle('active', idx === current);
      });
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => go(current + 1), 6000);
    };

    const stop = () => {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', start);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  })();
</script>
