---
import {
  getAboutVisionContentWithFallback,
  getAboutMissionItemsWithFallback,
  normalizeSiteLanguage,
} from '../../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));
const vision = await getAboutVisionContentWithFallback(language);
const misiList = await getAboutMissionItemsWithFallback(language);
---

<section
  id="visi-misi"
  class="border-t border-brand-border bg-brand-background px-8 py-32 max-[960px]:px-6 max-[960px]:py-16"
  aria-labelledby="visi-misi-title"
>
  <div class="mx-auto max-w-7xl">
    <header class="mb-20 max-w-180 max-[960px]:mb-12">
      <div
        class="mb-5 inline-flex items-center gap-3 text-[11.5px] font-medium uppercase tracking-[0.2em] text-brand-primary"
      >
        <span class="h-px w-8 bg-brand-primary"></span>
        <span>{vision.eyebrow}</span>
      </div>
      <h2
        id="visi-misi-title"
        class="m-0 font-serif text-[clamp(40px,5vw,64px)] font-normal leading-[1.05] tracking-tight text-brand-ink [&_em]:italic [&_em]:text-brand-primary"
        set:html={vision.title}
      />
    </header>

    <div
      class="grid grid-cols-[1fr_1.4fr] items-start gap-20 max-[960px]:grid-cols-1 max-[960px]:gap-12"
    >
      <aside class="sticky top-24 max-[960px]:static">
        <div
          class="relative rounded bg-brand-primary px-10 py-12 text-brand-background"
        >
          <div
            class="mb-6 text-[11.5px] font-medium uppercase tracking-[0.2em] text-brand-primary-lighter"
          >
            {vision.vision_eyebrow}
          </div>
          <p
            class="relative m-0 mb-6 font-serif text-[clamp(20px,2vw,24px)] font-light italic leading-normal text-brand-background"
          >
            <span
              class="mr-1 text-[1.2em] leading-none text-brand-primary-lighter align-[-0.1em]"
              >"</span
            >
            {vision.vision_quote}
          </p>
          <div
            class="border-t border-brand-background/15 pt-5 font-mono text-[11px] uppercase tracking-widest text-brand-primary-lighter"
          >
            — {vision.vision_attr}
          </div>
        </div>
      </aside>

      <div>
        <div
          class="mb-8 text-[11.5px] font-medium uppercase tracking-[0.2em] text-brand-primary"
        >
          {vision.mission_eyebrow}
        </div>
        <ol class="m-0 flex list-none flex-col p-0">
          {
            misiList.map((m, idx) => (
              <li class="grid grid-cols-[64px_1fr] items-start gap-6 border-b border-brand-border py-8 first:pt-0 last:border-b-0">
                <div class="pt-2 font-mono text-[13px] font-medium text-brand-primary">
                  {String(m.sort ?? idx + 1).padStart(2, '0')}
                </div>
                <div>
                  <h3 class="m-0 mb-2 font-serif text-[22px] font-medium leading-[1.2] tracking-[-0.015em] text-brand-ink">
                    {m.title}
                  </h3>
                  <p class="m-0 max-w-[56ch] text-[15px] leading-[1.6] text-brand-ink-soft">
                    {m.desc}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
