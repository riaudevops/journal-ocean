---
import {
  getAboutHeaderContentWithFallback,
  getAboutPillarItemsWithFallback,
  getAboutPillarsContentWithFallback,
  getAboutProfileContentWithFallback,
  normalizeSiteLanguage,
} from '../../../lib/directus';

const language = normalizeSiteLanguage(Astro.url.searchParams.get('lang'));

const aboutHeader = await getAboutHeaderContentWithFallback();
const aboutProfile = await getAboutProfileContentWithFallback(language);
const aboutPillars = await getAboutPillarsContentWithFallback(language);
const pillars = await getAboutPillarItemsWithFallback(language);
const heroImage = aboutHeader.image;
const heroEyebrow = aboutHeader.eyebrow;
const heroTitle = aboutHeader.title;
const heroSubtitle = aboutHeader.subtitle;
const heroDesc = aboutHeader.desc;
const profileTitle = aboutProfile.title;
const profileStroked = aboutProfile.stroked;
const profileDesc1 = aboutProfile.desc_1;
const profileDesc2 = aboutProfile.desc_2;
const profileImage = aboutProfile.image_1;
const profileImage2 = aboutProfile.image_2;
---

<section
  class="relative flex min-h-[56vh] items-center overflow-hidden bg-brand-primary text-brand-background"
  aria-labelledby="page-hero-title"
>
  <div
    class="absolute inset-0 bg-cover bg-center brightness-[0.7] saturate-[0.7]"
    style={`background-image: url('${heroImage}');`}
    role="img"
    aria-label={aboutHeader.image_alt}
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(135deg,rgba(74,93,63,0.85)_0%,rgba(42,46,37,0.7)_100%)]"
  >
  </div>

  <div
    class="relative z-2 mx-auto w-full max-w-7xl px-8 py-32 max-[960px]:px-6 max-[960px]:py-24"
  >
    <div
      class="mb-7 inline-flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.24em] text-brand-primary-lighter"
    >
      <span class="h-px w-10 bg-brand-primary-lighter"></span>
      <span>{heroEyebrow}</span>
    </div>
    <h1
      id="page-hero-title"
      class="m-0 max-w-[12ch] font-serif text-[clamp(48px,8vw,112px)] font-light leading-[0.9] tracking-tighter [&_em]:italic [&_em]:text-brand-primary-lighter"
      set:html={heroTitle}
    />
    <p
      class="mt-6 max-w-2xl font-serif text-[clamp(20px,2.5vw,32px)] italic leading-tight text-brand-background/90"
    >
      {heroSubtitle}
    </p>
    <p
      class="mt-4 max-w-[58ch] text-[15px] leading-[1.7] text-brand-background/75"
    >
      {heroDesc}
    </p>
  </div>
</section>

<section
  id="profile"
  class="bg-brand-background px-8 py-24 max-[960px]:px-6 max-[960px]:py-16"
>
  <div
    class="mx-auto grid max-w-7xl grid-cols-[0.9fr_1.1fr] items-center gap-20 max-[960px]:grid-cols-1 max-[960px]:gap-12"
  >
    <div>
      <div
        class="mb-6 inline-flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.2em] text-brand-primary"
      >
        <span class="h-px w-8 bg-brand-primary"></span>
        <span>{aboutProfile.eyebrow}</span>
      </div>

      <h2
        class="m-0 mb-8 max-w-[10ch] font-serif text-[clamp(44px,5.5vw,72px)] font-normal leading-[0.95] tracking-[-0.04em] text-brand-ink"
      >
        {profileTitle}
        <em class="block font-light italic text-brand-primary"
          >{profileStroked}</em
        >
      </h2>

      <p
        class="mb-5 max-w-[58ch] text-[16px] leading-[1.85] text-brand-ink-soft"
      >
        {profileDesc1}
      </p>
      <p
        class="mb-5 max-w-[58ch] text-[16px] leading-[1.85] text-brand-ink-soft"
      >
        {profileDesc2}
      </p>

      <div
        class="mt-9 flex items-center gap-4 border-t border-brand-border pt-7"
      >
        <div
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-primary font-serif text-xl italic text-brand-background"
        >
          {aboutProfile.signature_initial}
        </div>
        <div class="text-sm font-semibold text-brand-ink">
          {aboutProfile.signature_title}
          <small class="mt-1 block text-xs font-normal text-brand-ink-faint">
            {aboutProfile.signature_subtitle}
          </small>
        </div>
      </div>
    </div>

    <div class="relative mx-auto w-full max-w-xl">
      <img
        src={profileImage}
        alt={aboutProfile.image_alt_1}
        class="aspect-4/5 w-full rounded object-cover shadow-[0_24px_80px_rgba(42,46,37,0.12)]"
        loading="lazy"
      />
      <div
        class="absolute -left-6 top-6 rounded bg-brand-primary px-6 py-5 text-brand-background shadow-[0_8px_24px_rgba(42,46,37,0.15)] max-[960px]:-left-2 max-[960px]:top-4"
      >
        <div class="font-serif text-[40px] font-normal leading-none">
          {aboutProfile.stat}
        </div>
        <div
          class="mt-1.5 text-[10.5px] font-medium uppercase tracking-[0.15em] text-brand-primary-lighter"
        >
          {aboutProfile.stat_label}
        </div>
      </div>
      <img
        src={profileImage2}
        alt={aboutProfile.image_alt_2}
        class="absolute -bottom-8 -right-8 aspect-square w-1/2 rounded border-[6px] border-brand-background object-cover shadow-[0_12px_40px_rgba(42,46,37,0.15)] max-[960px]:-bottom-4 max-[960px]:-right-4"
        loading="lazy"
      />
    </div>
  </div>
</section>

<section
  class="border-y border-brand-border bg-brand-sand px-8 py-24 max-[960px]:px-6 max-[960px]:py-16"
>
  <div class="mx-auto max-w-7xl">
    <div
      class="mb-16 grid grid-cols-[1.4fr_1fr] items-end gap-16 max-[960px]:grid-cols-1 max-[960px]:gap-6"
    >
      <div>
        <div
          class="mb-5 text-[11.5px] font-medium uppercase tracking-[0.2em] text-brand-primary"
        >
          {aboutPillars.eyebrow}
        </div>
        <h3
          class="m-0 max-w-[20ch] font-serif text-[clamp(36px,4.5vw,56px)] font-normal leading-[1.05] tracking-tight text-brand-ink [&_em]:italic [&_em]:text-brand-primary"
          set:html={aboutPillars.title}
        />
      </div>
      <p
        class="m-0 ml-auto max-w-[44ch] text-[15px] leading-[1.6] text-brand-ink-soft max-[960px]:ml-0"
      >
        {aboutPillars.intro}
      </p>
    </div>

    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(min(300px,100%),1fr))] items-stretch gap-6"
    >
      {
        pillars.map((p, idx) => (
          <div class="relative h-full min-w-0 rounded bg-brand-surface px-8 py-9 transition duration-400 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(42,46,37,0.08)]">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary font-serif text-[22px] italic text-brand-background">
              {p.initial}
            </div>
            <div class="absolute right-6 top-6 font-mono text-[11px] text-brand-ink-faint">
              {String(p.sort ?? idx + 1).padStart(2, '0')}
            </div>
            <div class="mb-3 font-serif text-[22px] font-medium tracking-[-0.015em] text-brand-ink">
              {p.name}
            </div>
            <div class="text-sm leading-[1.6] text-brand-ink-soft">
              {p.desc}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
